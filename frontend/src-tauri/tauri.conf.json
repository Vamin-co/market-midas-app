{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Market Midas",
    "version": "0.1.0",
    "identifier": "com.marketmidas.app",
    "build": {
        "devUrl": "http://localhost:3001",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../out"
    },
    "app": {
        "withGlobalTauri": true,
        "security": {
            "csp": "default-src 'self'; connect-src 'self' http://localhost:3001 http://localhost:8000 ws://localhost:3001; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval'"
        },
        "windows": [
            {
                "title": "Market Midas",
                "width": 1440,
                "height": 900,
                "minWidth": 1280,
                "minHeight": 800,
                "decorations": true,
                "titleBarStyle": "Overlay",
                "hiddenTitle": true,
                "transparent": false,
                "resizable": true,
                "maximizable": true,
                "backgroundColor": "#141210",
                "center": true
            }
        ],
        "macOSPrivateApi": true
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}