{
    "$schema": "https://schemas.tauri.app/v2/schema/capability.json",
    "identifier": "default",
    "description": "Capability for the main Market Midas window",
    "windows": [
        "main"
    ],
    "permissions": [
        "core:default",
        "shell:allow-open",
        "core:window:allow-close",
        "core:window:allow-set-focus",
        "core:window:allow-start-dragging"
    ]
}