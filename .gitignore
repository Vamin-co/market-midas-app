# ═══════════════════════════════════════════════════════════
# Market-Midas .gitignore
# ═══════════════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# ── Node / Next.js ──
node_modules/
.next/
out/
frontend/.next/
frontend/node_modules/
frontend/src-tauri/target/

# ── Security: NEVER commit user secrets ──
config/settings.json

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Data & Logs ──
data/raw/
logs/
artifacts/

# ── Environment ──
.env
.env.local
.env.production
